# ─── TripGenius Environment Configuration ─────────────────────────────────────
# Copy this file to .env and fill in real values for production.

# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8080
PING_MESSAGE="ping pong"

# ─── Database ─────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/tripgenius

# ─── Authentication ───────────────────────────────────────────────────────────
# Used for JWT signing in the unused-but-better auth module (server/routes/auth.ts)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# ─── External APIs (optional – graceful fallbacks if missing) ─────────────────
OPENWEATHER_API_KEY=
OPENAI_API_KEY=
GOOGLE_MAPS_API_KEY=

# ─── Vite Public (exposed to browser – never put secrets here) ────────────────
VITE_PUBLIC_BUILDER_KEY=
